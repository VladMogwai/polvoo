{
  "name": "dev-dashboard",
  "version": "1.0.0",
  "description": "Developer Project Dashboard — like Docker Desktop for local dev projects",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.devdashboard.app",
    "productName": "Dev Dashboard",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "files": ["dist/**/*", "electron/**/*", "node_modules/**/*"],
    "asar": false
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}

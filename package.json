{
  "name": "dev-dashboard",
  "version": "1.0.4",
  "description": "Developer Project Dashboard — like Docker Desktop for local dev projects",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "build:local": "vite build && npx electron-builder --mac dmg --arm64 --publish never",
    "install:local": "./dev-install.sh",
    "release": "./release.sh",
    "release:fast": "./release-fast.sh",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.devdashboard.app",
    "productName": "Dev Dashboard",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "VladMogwai",
      "repo": "dev-dashboard"
    },
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ansi-to-html": "^0.7.2",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
